# ───────────────────────────────────────────────────────────────────────────
# Workspace OS — API environment variables
# Copy this file to `.env` at the repository root, then fill in the values.
# Only `apps/api/src/config/*` is allowed to read these variables.
# ───────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://workspace:workspace123@localhost:5433/workspace

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (JWT) — replace with strong random values in production
JWT_ACCESS_SECRET=replace_me_at_least_16_chars
JWT_REFRESH_SECRET=replace_me_at_least_16_chars_different
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
